# GitHub API Configuration
GITHUB_TOKEN=your_github_personal_access_token_here

# PostgreSQL Warehouse Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pipeone_warehouse
POSTGRES_USER=pipeone_user
POSTGRES_PASSWORD=your_secure_password_here

# Application Configuration
LOG_LEVEL=INFO
API_RATE_LIMIT_BUFFER=100

# =============================================================================
# Airflow Configuration — Added for H3: Airflow Orchestration
# =============================================================================
# These variables are required by docker-compose.yml to boot Airflow services.
# Copy this block into your .env file and fill in real values before running:
#   docker compose up -d

# Password for the dedicated Airflow metadata database.
# This DB is separate from the data warehouse — Airflow uses it to store
# DAG run history, task states, and user sessions.
# Choose any strong password (it does not need to match POSTGRES_PASSWORD).
AIRFLOW_POSTGRES_PASSWORD=your_airflow_db_password_here

# Fernet key — used by Airflow to encrypt sensitive values (connection passwords,
# Variables) stored in the metadata database. Must be a valid 32-byte base64 key.
# Generate with this one-liner (run once, keep the output):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here

# Secret key — used to sign Airflow's web session cookies.
# Generate with any random string generator, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=your_secret_key_here

# Airflow web UI admin credentials.
# Used only on first startup (airflow-init service creates this user).
# Change the username and password to something secure for shared environments.
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=your_airflow_admin_password_here

# =============================================================================
# Hacker News API Configuration — Added for Multi-Source Platform Evolution
# =============================================================================
# These variables configure the Hacker News ingestion client
# (src/ingestion/hn_client.py). The HN API is public and unauthenticated —
# no API key is required.

# Base URL for the official Hacker News Firebase API.
HN_BASE_URL=https://hacker-news.firebaseio.com/v0

# Maximum number of top stories to fetch per ingestion run.
# The HN API returns up to 500 top story IDs; this limits how many
# individual story details are fetched. Higher values increase run time.
HN_TOP_STORY_LIMIT=50

# HTTP request timeout in seconds for each individual API call.
HN_REQUEST_TIMEOUT=10

# User-Agent header sent with every HN API request.
HN_USER_AGENT=PipeOne-HackerNews-Analytics

# Maximum retry attempts for failed HTTP requests.
HN_MAX_RETRIES=3

# Base delay (seconds) for exponential backoff between retries.
# Actual delay: RETRY_BACKOFF * (2 ^ attempt_number)
HN_RETRY_BACKOFF=1.0
